{
  "name": "Auto Deploy ke Vercel",
  "version": "1.0.0",
  "description": "Otomatis git add, commit, dan push ke GitHub setiap kali agent selesai",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add . && git commit -m \"auto-deploy: update from Kiro\" && git push origin main || echo \"nothing to push\""
  }
}
